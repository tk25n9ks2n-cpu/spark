rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /photos/{photoId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /stories/{storyId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    match /swipes/{swipeId} {
      allow read: if isSignedIn() &&
        (resource.data.swiperId == request.auth.uid ||
         resource.data.swipedId == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.swiperId == request.auth.uid;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if isSignedIn() &&
        (resource.data.userAId == request.auth.uid ||
         resource.data.userBId == request.auth.uid);
      allow create: if isSignedIn() &&
        (request.resource.data.userAId == request.auth.uid ||
         request.resource.data.userBId == request.auth.uid);
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/matches/$(matchId)).data.userAId == request.auth.uid ||
           get(/databases/$(database)/documents/matches/$(matchId)).data.userBId == request.auth.uid);
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
          resource.data.senderId != request.auth.uid;
        allow delete: if false;
      }
    }
  }
}